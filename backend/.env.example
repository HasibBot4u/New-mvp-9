# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...        # anon public key
SUPABASE_SERVICE_KEY=eyJ...     # service_role secret key (NEVER expose to frontend)

# === TELEGRAM (Pyrogram) ===
TELEGRAM_API_ID=12345678        # From my.telegram.org
TELEGRAM_API_HASH=abcdef...     # From my.telegram.org
PYROGRAM_SESSION_STRING=...     # Primary account session
PYROGRAM_SESSION_STRING_2=...   # Backup account session (optional but recommended)

# === TELEGRAM BOT (python-telegram-bot) ===
TELEGRAM_BOT_TOKEN=123456:ABC... # From @BotFather
ADMIN_CHAT_ID=123456789         # YOUR personal Telegram user ID (from @userinfobot)
THUMBNAIL_CHANNEL_ID=-100...    # Private channel for thumbnails
WEBHOOK_URL=https://your-api.onrender.com/api/bot_webhook

# === RENDER / HOSTING ===
ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:5173
PORT=8080                       # Render sets this automatically

# === OPTIONAL ===
ADMIN_TOKEN=random-secret       # For HMAC admin signatures
VITE_CLOUDFLARE_WORKER_URL=...  # If using Cloudflare proxy for Drive
