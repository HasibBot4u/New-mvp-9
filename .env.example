# Frontend Environment Variables
# These MUST also be added to Netlify Dashboard → Site Settings → Environment Variables
# Vite inlines VITE_ variables at BUILD TIME — they cannot be changed after deploy
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_BASE_URL=http://localhost:8000

# Backend Environment Variables (for Python FastAPI)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
PYROGRAM_SESSION_STRING=your_pyrogram_session_string
ADMIN_TOKEN=your_admin_token
