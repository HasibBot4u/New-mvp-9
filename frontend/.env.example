# === FRONTEND ENV VARIABLES ===
# Create a .env.local file in the root of your frontend 
# Note: Vite bakes these into the code at BUILD TIME.

# Supabase Project URL (Get from Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (Get from Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJ... 

# URL of your Python Backend
VITE_API_BASE_URL=http://localhost:8000
