# ═══════════════════════════════════════════════════
# SECURITY WARNINGS
# ═══════════════════════════════════════════════════
# ⚠️ NEVER commit .env files to Git
# ⚠️ NEVER share your Supabase Service Key, Telegram Session Strings, or Bot Tokens in chat
# ⚠️ Rotate tokens immediately if they are exposed
#
# Deployment Instructions:
# - Local: Copy this file to `.env` (or `.env.local`) and fill in the values.
# - Render (Production): Add these variables in the Render Dashboard -> Environment.

# ═══════════════════════════════════════════════════
# FRONTEND (Vite / React)
# ═══════════════════════════════════════════════════
# [REQUIRED] type: HttpUrl - Supabase Project URL (Frontend)
VITE_SUPABASE_URL=https://fake-project-ref.supabase.co

# [REQUIRED] type: SecretStr - Supabase Anon Key (Frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...fake_anon_key

# [REQUIRED] type: HttpUrl - Backend API Base URL
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# [OPTIONAL] type: HttpUrl - Cloudflare Worker URL
VITE_CLOUDFLARE_WORKER_URL=https://fake-worker.yourdomain.workers.dev

# ═══════════════════════════════════════════════════
# BACKEND CORE (FastAPI)
# ═══════════════════════════════════════════════════
# [REQUIRED] type: str - Redis URL
REDIS_URL=rediss://default:fake_password@fake-redis-host:6379

# [OPTIONAL] type: int - Port for FastAPI to run on locally
PORT=8000

# [REQUIRED] type: str - Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.netlify.app

# [REQUIRED] type: SecretStr - JWT Secret for internal authentication
JWT_SECRET=super_secret_jwt_key_that_must_be_at_least_32_bytes_long

# [REQUIRED] type: int - Rate limiting configurations
RATE_LIMIT_PER_MINUTE=60

# [OPTIONAL] type: SecretStr - Admin token
ADMIN_TOKEN=fake_admin_token_abcdef1234567890

# ═══════════════════════════════════════════════════
# SUPABASE DATABASE (Backend)
# ═══════════════════════════════════════════════════
# [REQUIRED] type: HttpUrl - Supabase Project URL
SUPABASE_URL=https://fake-project-ref.supabase.co

# [REQUIRED] type: SecretStr - Supabase Anon Key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...fake_anon_key

# [REQUIRED] type: SecretStr - Supabase Service Role Key (NEVER expose to frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...fake_service_role_key

# ═══════════════════════════════════════════════════
# TELEGRAM CONFIGURATION
# ═══════════════════════════════════════════════════
# [REQUIRED] type: int - Telegram API ID
TELEGRAM_API_ID=12345678

# [REQUIRED] type: SecretStr - Telegram API Hash
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# [REQUIRED] type: SecretStr - Pyrogram session strings
PYROGRAM_SESSION_STRING=AgAfakeSessionString123456...

# [REQUIRED] type: SecretStr - Telegram Bot Token
TELEGRAM_BOT_TOKEN=1234567890:AAHfakeBotTokenStringHere...

# [REQUIRED] type: int - Admin Chat ID
ADMIN_CHAT_ID=123456789

# [REQUIRED] type: int - Private channel for uploading thumbnails
THUMBNAIL_CHANNEL_ID=-1001234567890

# [REQUIRED] type: HttpUrl - Public URL for the webhook
WEBHOOK_URL=https://fake-backend.onrender.com/api/bot_webhook

# ═══════════════════════════════════════════════════
# OPTIONAL / ADVANCED
# ═══════════════════════════════════════════════════
# [OPTIONAL] type: SecretStr - Secondary session string
PYROGRAM_SESSION_STRING_2=AgAfakeSessionString098765...

# [OPTIONAL] type: int - Channels to scan/upload items to
PHY_C1_CHANNEL_ID=-1009999999901
PHY_C2_CHANNEL_ID=-1009999999902
CHE_C1_CHANNEL_ID=-1009999999911
