# ═══════════════════════════════════════════════════
# SECURITY WARNINGS
# ═══════════════════════════════════════════════════
# ⚠️ NEVER commit .env files to Git
# ⚠️ NEVER share your Supabase Service Key, Telegram Session Strings, or Bot Tokens in chat
# ⚠️ Rotate tokens immediately if they are exposed
#
# Deployment Instructions:
# - Local: Copy this file to `.env` and fill in the values.
# - Render (Production): Add these variables in the Render Dashboard -> Environment.

# ═══════════════════════════════════════════════════
# BACKEND CORE
# ═══════════════════════════════════════════════════
# [OPTIONAL] Allowed origins for CORS (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.netlify.app

# [OPTIONAL] Port for FastAPI to run on locally (Render sets this automatically)
PORT=8000

# [OPTIONAL] Admin token for secure endpoints (generate a random 64-char string)
ADMIN_TOKEN=fake_admin_token_abcdef1234567890

# [REQUIRED] Redis URL for caching or task queues (Get from Render/Upstash/RedisLabs)
REDIS_URL=rediss://default:fake_password@fake-redis-host:6379

# ═══════════════════════════════════════════════════
# SUPABASE DATABASE
# ═══════════════════════════════════════════════════
# [REQUIRED] Supabase Project URL (Get from Supabase Dashboard -> Settings -> API)
SUPABASE_URL=https://fake-project-ref.supabase.co

# [REQUIRED] Supabase Service Role Key (Get from Supabase Dashboard -> Settings -> API)
# WARNING: NEVER expose this to the frontend. It bypasses Row Level Security.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...fake_service_role_key

# [REQUIRED] Supabase Anon Key (Get from Supabase Dashboard -> Settings -> API)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...fake_anon_key

# ═══════════════════════════════════════════════════
# TELEGRAM CONFIGURATION
# ═══════════════════════════════════════════════════
# [REQUIRED] Telegram API parameters (Get from https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# [REQUIRED] Pyrogram session strings (Generated locally using the generation script)
PYROGRAM_SESSION_STRING=AgAfakeSessionString123456...
# [OPTIONAL] Secondary session string for load balancing or avoiding rate limits
PYROGRAM_SESSION_STRING_2=AgAfakeSessionString098765...

# [REQUIRED] Telegram Bot Token (Get from @BotFather in Telegram)
TELEGRAM_BOT_TOKEN=1234567890:AAHfakeBotTokenStringHere...

# [REQUIRED] Admin Chat ID for logs and notifications (Get from @userinfobot)
ADMIN_CHAT_ID=123456789

# [REQUIRED] Private channel for uploading thumbnails (Create a private channel, get ID starting with -100)
THUMBNAIL_CHANNEL_ID=-1001234567890

# [REQUIRED] Public URL for the webhook (e.g., your Render URL + /api/bot_webhook)
WEBHOOK_URL=https://fake-backend.onrender.com/api/bot_webhook

# ═══════════════════════════════════════════════════
# OPTIONAL / ADVANCED (CHANNEL IDS FOR SCAN/UPLOAD)
# ═══════════════════════════════════════════════════
# [OPTIONAL] Channels to scan/upload items to. (Must start with -100)
PHY_C1_CHANNEL_ID=-1009999999901
PHY_C2_CHANNEL_ID=-1009999999902
PHY_C3_CHANNEL_ID=-1009999999903
PHY_C4_CHANNEL_ID=-1009999999904
PHY_C5_CHANNEL_ID=-1009999999905
PHY_C6_CHANNEL_ID=-1009999999906
CHE_C1_CHANNEL_ID=-1009999999911
CHE_C2_CHANNEL_ID=-1009999999912
CHE_C3_CHANNEL_ID=-1009999999913
CHE_C4_CHANNEL_ID=-1009999999914
CHE_C5_CHANNEL_ID=-1009999999915
CHE_C6_CHANNEL_ID=-1009999999916
HM_C1_CHANNEL_ID=-1009999999921
HM_C2_CHANNEL_ID=-1009999999922
HM_C3_CHANNEL_ID=-1009999999923
HM_C4_CHANNEL_ID=-1009999999924
HM_C5_CHANNEL_ID=-1009999999925
HM_C6_CHANNEL_ID=-1009999999926

