# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION (.env.example)
# ==============================================================================
# ⚠️ SECURITY WARNING ⚠️
# - NEVER commit your actual `.env` file to version control.
# - This `.env.example` file is safe to commit because it only contains placeholders.
# - In local development, copy this file to `.env` and fill in the values.
# - In production (Render, Netlify), enter these variables in their dashboards.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🟢 FRONTEND VARIABLES (Required for Vite/React)
# ------------------------------------------------------------------------------
# These MUST start with 'VITE_' to be visible to the frontend code.
# Where to set: Netlify Dashboard -> Site settings -> Environment variables.
# Note: Vite bakes these into the code at BUILD TIME.

# Supabase Project URL (Get from Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (Get from Supabase Dashboard -> Project Settings -> API)
# This is safe to expose in the browser (relies on RLS for security).
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# URL of your Python Backend (e.g., https://your-backend.onrender.com)
VITE_API_BASE_URL=http://localhost:8000


# ------------------------------------------------------------------------------
# 🟣 BACKEND VARIABLES (Required for Python/FastAPI)
# ------------------------------------------------------------------------------
# Where to set: Render Dashboard -> Web Service -> Environment Variables.

# Supabase Project URL (Same as frontend)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key (Get from Supabase Dashboard -> Project Settings -> API)
# DANGER: NEVER share this! It bypasses RLS rules. Backend use only.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Supabase Anon Key (Same as frontend, backend uses it for public endpoints validation)
SUPABASE_ANON_KEY=your_supabase_anon_key


# ------------------------------------------------------------------------------
# 🔵 TELEGRAM API & BOT VARIABLES
# ------------------------------------------------------------------------------
# Required for Telegram storage to function. Get from my.telegram.org

# Telegram API ID (Must be an integer e.g., 12345678)
TELEGRAM_API_ID=your_telegram_api_id

# Telegram API Hash (String, e.g., 'abcdef123456...')
TELEGRAM_API_HASH=your_telegram_api_hash

# Pyrogram Session String (Generated locally using generator script)
# Allows the backend to login as your user without needing 2FA codes.
PYROGRAM_SESSION_STRING=your_pyrogram_session_string
# Optional second session string for load balancing/rate limit bypass
PYROGRAM_SESSION_STRING_2=your_pyrogram_session_string_2

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Admin Chat ID (The User/Group ID where bot sends crash alerts/upload logs)
ADMIN_CHAT_ID=your_admin_chat_id_here

# Thumbnail Channel ID (Must start with -100)
THUMBNAIL_CHANNEL_ID=-100xxxxxxxxxxx

# Webhook URL for the bot (Render public URL + /api/bot_webhook)
WEBHOOK_URL=https://your-app-url.onrender.com/api/bot_webhook


# ------------------------------------------------------------------------------
# 🔴 SECURITY & ADMIN CONFIGURATION
# ------------------------------------------------------------------------------

# Token for executing backend endpoints securely (generate a strong random string)
ADMIN_TOKEN=your_securely_generated_64_char_admin_token

# Allowed CORS origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://nexusedu.netlify.app,http://localhost:5173

